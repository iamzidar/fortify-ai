# === Common ===
NODE_ENV=development
INTERNAL_SERVICE_SECRET=change-me-in-production

# === JWT ===
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=8h

# === Fortify SSC ===
FCLI_DEFAULT_SSC_URL=https://fortify.kikoichi.dev/ssc

# === Anthropic ===
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# === Redis ===
REDIS_URL=redis://redis:6379

# === PostgreSQL ===
POSTGRES_USER=fortify
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=fortify_audit
DATABASE_URL=postgresql://fortify:change-me-in-production@postgres:5432/fortify_audit

# === Service Ports ===
FRONTEND_PORT=3000
API_GATEWAY_PORT=3001
AUTH_SERVICE_PORT=3002
SSC_SERVICE_PORT=3003
AI_SERVICE_PORT=3004
DASHBOARD_SERVICE_PORT=3005

# === CORS ===
CORS_ORIGIN=http://localhost:3000
